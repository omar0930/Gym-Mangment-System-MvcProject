@model TrainerToUpdateViewModel
@{
    ViewData["Title"] = "Edit Trainer";
}

<div class="container">
    <main role="main" class="pb-3">
        <header class="mb-4 mt-4">
            <h3 class="text-primary-color">Edit Trainer</h3>
            <p class="text-muted">Update trainer details</p>
        </header>

        <form asp-controller="Trainer" asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="section-header mb-3">
                <h5 class="text-primary fw-bold">Personal Information</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="Name" class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-control" readonly />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="Gender" class="form-label">Gender</label>
                    <input asp-for="Gender" class="form-control" readonly />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="DateOfBirth" class="form-label">Date Of Birth</label>
                    <input asp-for="DateOfBirth" class="form-control" readonly />
                </div>
            </div>

            <div class="section-header mb-3 mt-4">
                <h5 class="text-primary fw-bold">Contact Information</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Phone" class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="section-header mb-3 mt-4">
                <h5 class="text-primary fw-bold">Address</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="Street" class="form-label">Street</label>
                    <input asp-for="Street" class="form-control" />
                    <span asp-validation-for="Street" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control" />
                    <span asp-validation-for="State" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="ZipCode" class="form-label">Zip Code</label>
                    <input asp-for="ZipCode" class="form-control" />
                    <span asp-validation-for="ZipCode" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="BuildingNumber" class="form-label">Building Number</label>
                    <input asp-for="BuildingNumber" class="form-control" />
                    <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="section-header mb-3 mt-4">
                <h5 class="text-primary fw-bold">Professional Information</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="Specialty" class="form-label">Specialization</label>
                    <select asp-for="Specialty" class="form-select" asp-items="Html.GetEnumSelectList<Specialty>()"></select>
                    <span asp-validation-for="Specialty" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="Salary" class="form-label">Salary (EGP)</label>
                    <input asp-for="Salary" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Salary" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="YearsOfExperience" class="form-label">Years Of Experience</label>
                    <input asp-for="YearsOfExperience" type="number" class="form-control" />
                    <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
                </div>
            </div>

            <footer class="d-flex justify-content-between mt-4 pt-3 border-top">
                <a asp-controller="Trainer" asp-action="Index" class="btn btn-outline">
                    <i class="bi bi-arrow-left me-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-fill">
                    <i class="bi bi-check-lg me-1"></i>Update Trainer
                </button>
            </footer>
        </form>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
