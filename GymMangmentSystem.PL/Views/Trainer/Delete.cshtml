@model TrainerViewModel
@{
    ViewData["Title"] = "Delete Trainer";
}

<div class="container">
    <main role="main" class="pb-3">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-7">
                    <div class="card shadow-lg border-0">
                        <div class="card-header bg-danger text-white text-center py-4">
                            <i class="bi bi-exclamation-triangle display-5 mb-2"></i>
                            <h3 class="mb-0">Delete Trainer</h3>
                        </div>
                        <div class="card-body p-4">
                            <p class="fs-5 text-center mb-4">Are you sure you want to delete this trainer?</p>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Full Name</h6>
                                    <p class="mb-0 fw-bold">@Model.Name</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Specialization</h6>
                                    <p class="mb-0 fw-bold">@Model.Specialty</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Email</h6>
                                    <p class="mb-0 fw-bold">@Model.Email</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Phone</h6>
                                    <p class="mb-0 fw-bold">@Model.Phone</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Gender</h6>
                                    <p class="mb-0 fw-bold">@Model.Gender</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Years Of Experience</h6>
                                    <p class="mb-0 fw-bold">@Model.YearsOfExperience</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 p-4">
                            <form asp-controller="Trainer" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline flex-fill">
                                        <i class="bi bi-arrow-left me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-danger flex-fill">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
