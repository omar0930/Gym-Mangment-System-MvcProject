@model TrainerViewModel
@{
    ViewData["Title"] = "Trainer Details";
}

<div class="container">
    <main role="main" class="pb-3">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-lg border-0">
                        <div class="card-header bg-primary-color text-white text-center py-5">
                            <i class="bi bi-person-badge display-4 mb-3"></i>
                            <h2 class="mb-0">@Model.Name</h2>
                            <span class="badge bg-light text-primary-color mt-2">@Model.Specialty</span>
                        </div>
                        <div class="card-body p-4">

                            <h5 class="text-primary fw-bold">Personal Information</h5>
                            <hr class="mt-1 mb-3" />
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Gender</h6>
                                    <p class="mb-0 fw-bold">@Model.Gender</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Date Of Birth</h6>
                                    <p class="mb-0 fw-bold">@Model.DateOfBirth</p>
                                </div>
                            </div>

                            <h5 class="text-primary fw-bold">Contact Information</h5>
                            <hr class="mt-1 mb-3" />
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Phone</h6>
                                    <p class="mb-0 fw-bold">@Model.Phone</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Email</h6>
                                    <p class="mb-0 fw-bold">@Model.Email</p>
                                </div>
                            </div>

                            <h5 class="text-primary fw-bold">Address</h5>
                            <hr class="mt-1 mb-3" />
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">Street</h6>
                                    <p class="mb-0 fw-bold">@Model.Street</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">City</h6>
                                    <p class="mb-0 fw-bold">@Model.City</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="mb-0 text-muted">State</h6>
                                    <p class="mb-0 fw-bold">@(string.IsNullOrWhiteSpace(Model.State) ? "-" : Model.State)</p>
                                </div>
                            </div>

                            <h5 class="text-primary fw-bold">Professional Information</h5>
                            <hr class="mt-1 mb-3" />
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <h6 class="mb-0 text-muted">Specialization</h6>
                                    <p class="mb-0 fw-bold">@Model.Specialty</p>
                                </div>
                                <div class="col-md-4">
                                    <h6 class="mb-0 text-muted">Salary</h6>
                                    <p class="mb-0 fw-bold">@Model.Salary EGP</p>
                                </div>
                                <div class="col-md-4">
                                    <h6 class="mb-0 text-muted">Years Of Experience</h6>
                                    <p class="mb-0 fw-bold">@Model.YearsOfExperience</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 p-4">
                            <div class="d-flex justify-content-between gap-2">
                                <a asp-action="Index" class="btn btn-outline flex-fill">
                                    <i class="bi bi-arrow-left me-1"></i>Back
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-fill flex-fill">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
