@model CreateTrainerViewModel
@{
    ViewData["Title"] = "Add Trainer";
}

<div class="container">
    <main role="main" class="pb-3">
        <header class="mb-4 mt-4">
            <h3 class="text-primary-color">Add Trainer</h3>
            <p class="text-muted">Create a new trainer profile</p>
        </header>

        <form asp-controller="Trainer" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="section-header mb-3">
                <h5 class="text-primary fw-bold">Personal Information</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="FirstName" class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="LastName" class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Gender" class="form-label">Gender</label>
                    <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Gender>()">
                        <option value="">-- Select Gender --</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="DateOfBirth" class="form-label">Date Of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Phone" class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="section-header mb-3 mt-4">
                <h5 class="text-primary fw-bold">Address</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="Street" class="form-label">Street</label>
                    <input asp-for="Street" class="form-control" />
                    <span asp-validation-for="Street" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control" />
                    <span asp-validation-for="State" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="ZipCode" class="form-label">Zip Code</label>
                    <input asp-for="ZipCode" class="form-control" />
                    <span asp-validation-for="ZipCode" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="BuildingNumber" class="form-label">Building Number</label>
                    <input asp-for="BuildingNumber" class="form-control" />
                    <span asp-validation-for="BuildingNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="section-header mb-3 mt-4">
                <h5 class="text-primary fw-bold">Professional Information</h5>
                <hr class="mt-2" />
            </div>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="Specialty" class="form-label">Specialization</label>
                    <select asp-for="Specialty" class="form-select" asp-items="Html.GetEnumSelectList<Specialty>()">
                        <option value="">-- Select Specialization --</option>
                    </select>
                    <span asp-validation-for="Specialty" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="Salary" class="form-label">Salary (EGP)</label>
                    <input asp-for="Salary" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Salary" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="YearsOfExperience" class="form-label">Years Of Experience</label>
                    <input asp-for="YearsOfExperience" type="number" class="form-control" />
                    <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
                </div>
            </div>

            <footer class="d-flex justify-content-end gap-3 mt-4">
                <a asp-controller="Trainer" asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i> Add
                </button>
            </footer>
        </form>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
