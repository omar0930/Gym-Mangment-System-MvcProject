@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string NavActive(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Thambi+2:wght@400..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
          rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Main CSS -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/images/logo.svg" />
    <title>Body Factory | @ViewData["Title"]</title>
</head>
<body>
    <header>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg bg-white my-3">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.svg" alt="Body Factory Gym" height="44" />
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">

                    <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Home")"
                                   asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-2"></i>Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Members")"
                                   asp-controller="Members" asp-action="Index">
                                <i class="bi bi-people-fill me-2"></i>Members
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Trainer")"
                                   asp-controller="Trainer" asp-action="Index">
                                <i class="bi bi-person-badge-fill me-2"></i>Trainers
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Session")"
                                   asp-controller="Session" asp-action="Index">
                                <i class="bi bi-calendar-event-fill me-2"></i>Sessions
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Plan")"
                                   asp-controller="Plan" asp-action="Index">
                                <i class="bi bi-card-checklist me-2"></i>Plans
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("Membership")"
                                   asp-controller="Membership" asp-action="Index">
                                <i class="bi bi-award-fill me-2"></i>Memberships
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5 @NavActive("SessionSchedule")"
                                   asp-controller="SessionSchedule" asp-action="Index">
                                <i class="bi bi-calendar2-week-fill me-2"></i>Sessions Schedule
                            </a>
                        </li>

                        <li class="nav-item">
                            <form action="\Account\Logout" method="post" class="d-inline">
                                <button type="submit"
                                        class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </button>
                            </form>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
