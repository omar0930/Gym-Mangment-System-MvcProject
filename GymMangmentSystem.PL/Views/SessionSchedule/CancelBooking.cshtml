@model BookingViewModel
@{
    ViewData["Title"] = "Cancel Booking";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 text-center">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="bi bi-exclamation-triangle-fill text-warning display-1"></i>
                    </div>

                    <h3 class="text-primary-color mb-3">Cancel Booking</h3>

                    <div class="alert alert-warning text-start mb-4">
                        <strong><i class="bi bi-info-circle me-2"></i>Warning:</strong>
                        This will release the member's seat in this session. This action cannot be undone.
                    </div>
                    <p class="text-muted mb-2">Are you sure you want to cancel this booking?</p>
                    <p class="fw-semibold mb-4">@Model.MemberName — @Model.CategoryName (@Model.SessionDateDisplay)</p>

                    <form asp-action="CancelConfirmed" asp-route-memberId="@Model.MemberId" asp-route-sessionId="@Model.SessionId" method="post">
                        <div class="d-flex justify-content-between gap-3">
                            <a asp-action="Index" class="btn btn-outline flex-fill">
                                <i class="bi bi-arrow-left me-1"></i>Keep Booking
                            </a>
                            <button type="submit" class="btn btn-fill bg-danger border-danger flex-fill">
                                <i class="bi bi-x-circle me-1"></i>Cancel Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
