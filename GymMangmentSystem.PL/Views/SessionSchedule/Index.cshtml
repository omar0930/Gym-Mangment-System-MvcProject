@model IEnumerable<BookingViewModel>
@{
    ViewData["Title"] = "Sessions Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Sessions Schedule</h2>
            <p class="text-muted">Manage member bookings for training sessions</p>
        </div>
        <a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-plus-lg me-2"></i>Book Session
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Member</th>
                            <th>Session</th>
                            <th>Trainer</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Attendance</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@booking.MemberName</td>
                                <td>@booking.CategoryName</td>
                                <td>@booking.TrainerName</td>
                                <td>@booking.SessionDateDisplay</td>
                                <td>@booking.SessionTimeDisplay</td>
                                <td>
                                    <span class="badge @(booking.Status == "Ongoing" ? "bg-success" : booking.Status == "Upcoming" ? "bg-primary" : "bg-secondary")">
                                        @booking.Status
                                    </span>
                                </td>
                                <td>
                                    @if (booking.IsAttended)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Attended</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark"><i class="bi bi-dash-circle me-1"></i>Not Attended</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Details" asp-route-memberId="@booking.MemberId" asp-route-sessionId="@booking.SessionId" class="btn btn-outline btn-sm" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="MarkAttendance" asp-route-memberId="@booking.MemberId" asp-route-sessionId="@booking.SessionId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-outline btn-sm text-success" title="Toggle attendance">
                                                <i class="bi bi-clipboard-check"></i>
                                            </button>
                                        </form>
                                        <a asp-action="Cancel" asp-route-memberId="@booking.MemberId" asp-route-sessionId="@booking.SessionId" class="btn btn-outline btn-sm text-danger" title="Cancel booking">
                                            <i class="bi bi-x-circle"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar2-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Bookings Yet</h4>
            <p class="text-muted">Book a member into a session to get started</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertBoxScript.cshtml" />
}
