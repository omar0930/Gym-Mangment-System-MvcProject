@model EditMembershipViewModel
@{
    ViewData["Title"] = "Edit Membership";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <header class="mb-4">
        <h3 class="text-primary-color">Edit Membership</h3>
        <p class="text-muted">Adjust the membership end date</p>
    </header>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="MemberId" />
        <input type="hidden" asp-for="PlanId" />
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="MemberName" class="form-label fw-semibold">Member</label>
                                <input asp-for="MemberName" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PlanName" class="form-label fw-semibold">Plan</label>
                                <input asp-for="PlanName" class="form-control" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-semibold">
                                    End Date <span class="text-danger">*</span>
                                </label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger d-block"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-fill">
                                <i class="bi bi-check-lg me-1"></i>Update Membership
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
