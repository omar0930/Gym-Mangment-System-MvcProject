@model IEnumerable<MembershipViewModel>
@{
    ViewData["Title"] = "Memberships";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="Alert" class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Memberships</h2>
            <p class="text-muted">Assign and manage member subscriptions</p>
        </div>
        <a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-plus-lg me-2"></i>Assign Membership
        </a>
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var membership in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header text-white py-3 @(membership.IsActive ? "bg-success" : "bg-secondary")">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-person-badge me-2"></i>@membership.MemberName
                                </h5>
                                <span class="badge bg-light text-dark">@membership.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="session-info mb-3">
                                <div class="info-item mb-2">
                                    <i class="bi bi-award text-primary-color me-2"></i>
                                    <strong>Plan:</strong> @membership.PlanName
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-cash-coin text-primary-color me-2"></i>
                                    <strong>Price:</strong> @membership.Price EGP
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                    <strong>Start:</strong> @membership.StartDateDisplay
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-calendar-x text-primary-color me-2"></i>
                                    <strong>End:</strong> @membership.EndDateDisplay
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-hourglass-split text-primary-color me-2"></i>
                                    <strong>Days Remaining:</strong> @membership.DaysRemaining
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-memberId="@membership.MemberId" asp-route-planId="@membership.PlanId" class="btn btn-outline btn-sm">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-memberId="@membership.MemberId" asp-route-planId="@membership.PlanId" class="btn btn-outline btn-sm flex-fill">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <form asp-action="Renew" asp-route-memberId="@membership.MemberId" asp-route-planId="@membership.PlanId" method="post" class="flex-fill">
                                        <button type="submit" class="btn btn-outline btn-sm w-100 text-success">
                                            <i class="bi bi-arrow-repeat me-1"></i>Renew
                                        </button>
                                    </form>
                                    <a asp-action="Delete" asp-route-memberId="@membership.MemberId" asp-route-planId="@membership.PlanId" class="btn btn-outline text-danger btn-sm flex-fill">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-person-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Memberships Found</h4>
            <p class="text-muted">Assign a plan to a member to get started</p>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertBoxScript.cshtml" />
}
