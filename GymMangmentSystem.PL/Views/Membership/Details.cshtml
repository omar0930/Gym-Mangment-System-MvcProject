@model MembershipViewModel
@{
    ViewData["Title"] = "Membership Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header @(Model.IsActive ? "bg-success" : "bg-secondary") text-white text-center py-4">
                    <i class="bi bi-person-badge display-4 mb-3"></i>
                    <h2 class="mb-2">@Model.MemberName</h2>
                    <span class="badge bg-light text-dark fs-6">@Model.Status</span>
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="detail-box p-3 border rounded">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-award text-primary-color fs-3"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Plan</small>
                                        <strong>@Model.PlanName</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-box p-3 border rounded">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-cash-coin text-primary-color fs-3"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Price</small>
                                        <strong>@Model.Price EGP</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-box p-3 border rounded">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-calendar-check text-primary-color fs-3"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Start Date</small>
                                        <strong>@Model.StartDate.ToString("MMM dd, yyyy")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="detail-box p-3 border rounded">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-calendar-x text-primary-color fs-3"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">End Date</small>
                                        <strong>@Model.EndDate.ToString("MMM dd, yyyy")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="detail-box p-3 border rounded bg-light">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3">
                                        <i class="bi bi-hourglass-split text-primary-color fs-3"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Days Remaining</small>
                                        <strong class="text-primary-color fs-5">@Model.DaysRemaining days</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4">
                    <div class="d-flex justify-content-between gap-2">
                        <a asp-action="Index" class="btn btn-outline flex-fill">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                        <a asp-action="Edit" asp-route-memberId="@Model.MemberId" asp-route-planId="@Model.PlanId" class="btn btn-fill flex-fill">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
